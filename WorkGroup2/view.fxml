<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.GridPane?>

<GridPane hgap="10" vgap="10" xmlns:fx="http://javafx.com/fxml"
          fx:controller="ScoreController">

    <Label text="Subject" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
    <ComboBox fx:id="subjectComboBox"
              GridPane.rowIndex="0" GridPane.columnIndex="1"/>

    <Label text="Midterm" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
    <TextField fx:id="midtermField"
               GridPane.rowIndex="1" GridPane.columnIndex="1"/>

    <Label text="Final" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
    <TextField fx:id="finalField"
               GridPane.rowIndex="2" GridPane.columnIndex="1"/>

    <Label text="Homework" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
    <TextField fx:id="homeworkField"
               GridPane.rowIndex="3" GridPane.columnIndex="1"/>

    <Button text="Calculate" onAction="#calculateScore"
            GridPane.rowIndex="4" GridPane.columnIndex="0"/>

    <Button text="Reset" onAction="#resetForm"
            GridPane.rowIndex="4" GridPane.columnIndex="1"/>

    <Button text="Save" onAction="#saveResult"
            GridPane.rowIndex="5" GridPane.columnIndex="0"/>

    <Label text="Total Score"
           GridPane.rowIndex="6" GridPane.columnIndex="0"/>

    <TextField fx:id="totalField" editable="false"
               GridPane.rowIndex="6" GridPane.columnIndex="1"/>

    <Label text="Status"
           GridPane.rowIndex="7" GridPane.columnIndex="0"/>

    <Label fx:id="statusLabel"
           GridPane.rowIndex="7" GridPane.columnIndex="1"/>

    <Label text="Grade"
           GridPane.rowIndex="8" GridPane.columnIndex="0"/>

    <Label fx:id="gradeLabel"
           GridPane.rowIndex="8" GridPane.columnIndex="1"/>

</GridPane>